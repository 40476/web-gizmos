<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gizmos | Lab Registry</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --primary: #12a8ff; /* Matched to HUD Frame default */
      --primary-glow: rgba(18, 168, 255, 0.3);
      --bg: #040e16;
      --nav-bg: rgba(4, 22, 34, 0.85);
      --card-bg: transparent; /* Background now handled by SVG */
      --text: #ececec;
      --text-muted: #64748b;
      --border: rgba(18, 168, 255, 0.2);
      --font-main: 'Inter', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
    }

    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; height: 100vh; width: 100%; overflow: hidden; font-family: var(--font-main); background: var(--bg); color: var(--text); }
    body { display: flex; background-image: radial-gradient(circle at 50% 50%, #0a1924 0%, #040e16 100%); }

    /* --- SIDEBAR --- */
    nav { width: 320px; min-width: 320px; background: var(--nav-bg); backdrop-filter: blur(20px); border-right: 1px solid var(--border); display: flex; flex-direction: column; height: 100vh; z-index: 100; }
    .nav-header { padding: 2rem 1.5rem 1rem 1.5rem; }
    .nav-header h2 { font-weight: 800; color: var(--text); margin: 0 0 1.5rem 0; font-size: 1.5rem; display: flex; align-items: center; gap: 0.5rem; }
    .nav-header h2::before { content: ''; width: 8px; height: 24px; background: var(--primary); border-radius: 4px; box-shadow: 0 0 15px var(--primary); }

    .search-wrapper { position: relative; margin-bottom: 0.5rem; }
    #search { width: 100%; padding: 12px 16px; background: rgba(0, 0, 0, 0.4); border: 1px solid var(--border); color: var(--text); border-radius: 4px; outline: none; font-family: var(--font-mono); font-size: 0.8rem; }
    
    .nav-scroll-area { flex: 1; overflow-y: auto; padding: 0 1rem; margin: 1rem 0; }
    .nav-item { display: flex; align-items: center; color: var(--text-muted); text-decoration: none; padding: 10px 12px; font-size: 0.85rem; border-radius: 4px; font-family: var(--font-mono); transition: 0.2s; }
    .nav-item:hover { background: rgba(18, 168, 255, 0.1); color: var(--primary); }

    /* --- MAIN CONTENT --- */
    main { flex: 1; padding: 3rem 2rem; overflow-y: auto; }
    .header-area { max-width: 900px; margin: 0 auto 4rem auto; }
    .header-area h1 { font-size: 3rem; font-weight: 800; letter-spacing: -0.04em; margin: 0; color: var(--primary); text-shadow: 0 0 20px var(--primary-glow); }

    #appContainer { max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: 3rem; }

    /* --- HUD CARD STYLING --- */
    .app-section {
      position: relative;
      padding: 40px; /* Padding for the frame padding */
      min-height: 150px;
      transition: transform 0.3s ease;
    }
    .app-section:hover { transform: translateX(10px); }

    .card-background {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      z-index: -1;
      pointer-events: none;
    }
    .card-background svg { width: 100%; height: 100%; display: block; }

    .card-content { position: relative; z-index: 2; }

    .run-btn {
      padding: 6px 14px;
      background: rgba(18, 168, 255, 0.2);
      border: 1px solid var(--primary);
      color: var(--primary);
      text-decoration: none;
      font-weight: 700;
      font-size: 0.7rem;
      font-family: var(--font-mono);
      text-transform: uppercase;
      transition: 0.2s;
    }
    .run-btn:hover { background: var(--primary); color: #000; box-shadow: 0 0 15px var(--primary); }

    .app-title { font-size: 1.5rem; margin: 0.5rem 0 1rem 0; font-weight: 700; color: #fff; }
    .summary-content { color: var(--text-muted); line-height: 1.6; font-size: 0.9rem; }
    
    @media (max-width: 950px) {
      body { flex-direction: column; overflow: auto; }
      nav { width: 100%; height: auto; border-right: none; border-bottom: 1px solid var(--border); }
      .nav-scroll-area { max-height: 150px; }
    }
  </style>
</head>
<body class="theme-auto">

  <nav>
    <div class="nav-header">
      <h2>GIZMOS</h2>
      <div class="search-wrapper">
        <input id="search" type="text" placeholder="ID_SEARCH_SYSTEM..." autocomplete="off" />
      </div>
    </div>

    <div class="nav-scroll-area">
      <div id="projectList">
        {% for name, summary in applications.items() %}
          <a class="nav-item" href="{{ name }}/index.html" data-name="{{ name }}">{{ name }}</a>
        {% endfor %}
      </div>
    </div>
  </nav>

  <main>
    <div class="header-area">
      <h1>LAB_REGISTRY</h1>
      <p style="color: var(--text-muted); font-family: var(--font-mono); font-size: 0.8rem; margin-top: 1rem;">>> INITIALIZING HUD_UI_OVERLAY... OK</p>
    </div>

    <div id="appContainer">
      {% for name, summary in applications.items() %}
        <section class="app-section" id="section-{{ name }}" data-name="{{ name }}" data-index="{{ loop.index }}">
          <div class="card-background"></div>
          <div class="card-content">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
              <div style="color: var(--primary); font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; opacity: 0.7;">
                UNIT_0{{ loop.index }}
              </div>
              <a class="run-btn" href="{{ name }}/index.html">Initialize</a>
            </div>
            <h2 class="app-title">{{ name }}</h2>
            <div class="summary-content">
              {{ summary | safe }}
            </div>
          </div>
        </section>
      {% endfor %}
    </div>
  </main>

  <script>
    /* --- HUD GENERATOR LOGIC (MINIFIED FOR INTEGRATION) --- */
    function mulberry32(a){return function(){a=a+1831565813|0;let t=Math.imul(a^a>>>15,1|a);t=t+Math.imul(t^t>>>7,61|t)^0;return((t^t>>>14)>>>0)/4294967296}}
    function rInt(r,a,b){return Math.floor(a+r()*(b-a+1))}
    function fmt(n){return Number(n.toFixed(2)).toString()}

    function generateHudFrameSVG({w, h, seed}) {
        const rng = mulberry32(seed);
        const pad = 20;
        const strokeOuter = "rgba(18,168,255,0.95)";
        const strokeInner = "rgba(18,168,255,0.2)";
        const panelFill = "rgba(4,22,34,0.7)";
        
        // Simplified generation logic for the cards
        const chamfer = rInt(rng, 10, 30);
        const outlineD = `M ${chamfer} 0 L ${w-chamfer} 0 L ${w} ${chamfer} L ${w} ${h-chamfer} L ${w-chamfer} h L ${chamfer} ${h} L 0 ${h-chamfer} L 0 ${chamfer} Z`;

        const svgMarkup = `
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="${-pad} ${-pad} ${w+pad*2} ${h+pad*2}" preserveAspectRatio="none">
                <defs>
                   <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
                       <feDropShadow dx="0" dy="0" stdDeviation="3" flood-color="#12a8ff" flood-opacity="0.5" />
                   </filter>
                </defs>
                <path d="${outlineD}" fill="${panelFill}" stroke="${strokeInner}" stroke-width="2" />
                <path d="${outlineD}" fill="none" stroke="${strokeOuter}" stroke-width="1" filter="url(#glow)" />
                <path d="M 0 ${chamfer+10} L 0 ${chamfer}" fill="none" stroke="${strokeOuter}" stroke-width="3" />
            </svg>`;
        return svgMarkup;
    }

    /* --- INITIALIZE CARDS --- */
    function renderFrames() {
        document.querySelectorAll('.app-section').forEach(section => {
            const container = section.querySelector('.card-background');
            const w = section.offsetWidth;
            const h = section.offsetHeight;
            const seed = parseInt(section.dataset.index) * 12345;
            
            container.innerHTML = generateHudFrameSVG({
                w: w,
                h: h,
                seed: seed
            });
        });
    }

    // Run on load and resize
    window.addEventListener('load', renderFrames);
    window.addEventListener('resize', renderFrames);

    // Search Logic (Preserved)
    const search = document.getElementById("search");
    search.addEventListener("input", e => {
      const term = e.target.value.toLowerCase();
      document.querySelectorAll(".app-section").forEach(sec => {
        const match = sec.dataset.name.toLowerCase().includes(term);
        sec.style.display = match ? "block" : "none";
      });
      renderFrames(); // Re-render frames for filtered list
    });
  </script>
</body>
</html>

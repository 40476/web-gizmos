<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Applications Overview</title>
  <style>
    :root {
      --primary: #01ff70;
      --bg: #111;
      --card-bg: #222;
      --text: #fafafa;
      --text-muted: #bbb;
      --border: #444;
      --code-bg: #333;
    }

    /* Light Theme Class (Triggered by JS) */
    body.theme-light {
      --primary: #0074d9;
      --bg: #f4f4f4;
      --card-bg: #ffffff;
      --text: #111;
      --text-muted: #444;
      --border: #ccc;
      --code-bg: #eee;
    }

    /* Pure CSS Auto-Detect (System Preference) */
    @media (prefers-color-scheme: light) {
      body:not(.theme-dark):not(.theme-light) {
        --primary: #0074d9;
        --bg: #f4f4f4;
        --card-bg: #ffffff;
        --text: #111;
        --text-muted: #444;
        --border: #ccc;
        --code-bg: #eee;
      }
    }

    html { scroll-behavior: smooth; font-family: "Courier New", Courier, monospace; }
    body { margin: 0; background: var(--bg); color: var(--text); display: flex; min-height: 100vh; transition: background 0.2s; }

    /* Hide search if no-script */
    .search-wrapper noscript + #search { display: none; }

    /* Layout */
    nav {
      width: 280px;
      background: #000;
      padding: 1.5rem;
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      box-sizing: border-box;
    }

    main { flex: 1; padding: 2rem; max-width: 900px; margin: 0 auto; width: 100%; box-sizing: border-box; }

    /* Pure CSS Theme Toggle UI */
    .theme-controls {
      margin-top: auto;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
      font-size: 0.8rem;
    }
    .theme-controls label { cursor: pointer; display: block; padding: 5px; color: var(--text-muted); }
    .theme-controls input { margin-right: 10px; }

    /* Responsive / Mobile Mode */
    @media (max-width: 850px) {
      body { flex-direction: column; }
      nav { width: 100%; height: auto; position: relative; border-right: none; border-bottom: 1px solid var(--border); }
      .nav-items-container { display: flex; overflow-x: auto; gap: 15px; padding-bottom: 10px; }
      .nav-item { white-space: nowrap; }
    }

    .app-section {
      background: var(--card-bg);
      padding: 1.5rem;
      margin-bottom: 2rem;
      border-radius: 8px;
      border: 1px solid var(--border);
    }

    .app-link { color: var(--primary); text-decoration: none; font-size: 0.7rem; text-transform: uppercase; font-weight: bold; }
    h1 { color: var(--primary); }
    h2 { border-bottom: 1px solid var(--border); padding-bottom: 5px; }
    pre { background: var(--code-bg); padding: 10px; overflow-x: auto; border-left: 3px solid var(--primary); }
    code { color: var(--primary); }

    footer { text-align: center; font-size: 0.8rem; color: var(--text-muted); margin-top: 3rem; }
    
    /* Highlight class for search */
    .highlight { background: var(--primary); color: #000; font-weight: bold; }
  </style>
</head>
<body class="theme-auto">

  <nav>
    <h2>GIZMOS</h2>
    
    <div class="search-wrapper">
      <noscript><style>#search { display: none !important; }</style></noscript>
      <input id="search" type="text" placeholder="Filter gizmos..." autocomplete="off" />
    </div>

    <div class="nav-items-container" id="sideNav">
      {% for name, summary in applications.items() %}
        <a class="nav-item" href="{{ name }}/index.html" data-name="{{ name }}">> {{ name }}</a>
      {% endfor %}
    </div>

    <div class="theme-controls">
      <p>THEME</p>
      <label><input type="radio" name="theme" value="theme-dark"> Dark</label>
      <label><input type="radio" name="theme" value="theme-light"> Light</label>
      <label><input type="radio" name="theme" value="theme-auto" checked> Auto</label>
    </div>
  </nav>

  <main>
    <h1>web-gizmos</h1>

    <div id="appContainer">
      {% for name, summary in applications.items() %}
        <section class="app-section" id="section-{{ name }}" data-name="{{ name }}">
          <a class="app-link" href="{{ name }}/index.html">[ Launch ]</a>
          <h2 class="app-title">{{ name }}</h2>
          <div class="summary-content">
            {{ summary | safe }}
          </div>
        </section>
      {% endfor %}
    </div>

    <footer>
      <p>Last Sync: {{ last_updated }}</p>
      <p>Total: {{ applications | length }} | JS Status: <script>document.write("Active")</script><noscript>Disabled</noscript></p>
    </footer>
  </main>

  <script>
    // 1. Search with Highlighting
    const search = document.getElementById("search");
    const sections = document.querySelectorAll(".app-section");
    const navItems = document.querySelectorAll(".nav-item");

    search.addEventListener("input", (e) => {
      const term = e.target.value.toLowerCase();
      
      sections.forEach(sec => {
        const name = sec.dataset.name.toLowerCase();
        const titleEl = sec.querySelector(".app-title");
        
        if (name.includes(term)) {
          sec.style.display = "block";
          // Highlight logic
          if (term.length > 0) {
            const regex = new RegExp(`(${term})`, "gi");
            titleEl.innerHTML = sec.dataset.name.replace(regex, `<span class="highlight">$1</span>`);
          } else {
            titleEl.textContent = sec.dataset.name;
          }
        } else {
          sec.style.display = "none";
        }
      });

      navItems.forEach(item => {
        item.style.display = item.dataset.name.toLowerCase().includes(term) ? "block" : "none";
      });
    });

    // 2. Theme Persistance & Logic
    const themeRadios = document.querySelectorAll('input[name="theme"]');
    
    function setTheme(theme) {
      document.body.className = theme;
      localStorage.setItem("gizmo-theme", theme);
    }

    themeRadios.forEach(radio => {
      radio.addEventListener("change", (e) => setTheme(e.target.value));
    });

    // Init theme
    const savedTheme = localStorage.getItem("gizmo-theme") || "theme-auto";
    setTheme(savedTheme);
    document.querySelector(`input[value="${savedTheme}"]`).checked = true;
  </script>
</body>
</html>

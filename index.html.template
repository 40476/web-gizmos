<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gizmos</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --primary: #12a8ff;
      --primary-glow: rgba(18, 168, 255, 0.5);
      --primary-dim: rgba(18, 168, 255, 0.15);
      --bg: #020b12;
      --card-bg: rgba(4, 22, 34, 0.85);
      --nav-bg: rgba(4, 22, 34, 0.95);
      --text: #ececec;
      --text-muted: #5a7b8f;
      --font-main: 'Inter', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
      --sidebar-width: 300px;
    }

    [data-theme="light"] {
      --bg: #f0f4f8;
      --card-bg: rgba(255, 255, 255, 0.9);
      --nav-bg: rgba(235, 240, 245, 0.95);
      --text: #1a2a3a;
      --text-muted: #5a7b8f;
      --primary-dim: rgba(18, 168, 255, 0.1);
    }

    * { box-sizing: border-box; }
    html, body { 
      margin: 0; padding: 0; 
      height: 100vh; width: 100%; 
      font-family: var(--font-main); 
      background: var(--bg); 
      color: var(--text); 
      transition: background-color 0.3s ease, color 0.3s ease;
      overflow: hidden;
    }

    body { display: flex; }

    /* --- MOBILE HEADER (Toggle for Sidebar) --- */
    .mobile-nav-bar {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 60px;
      background: var(--nav-bg);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--primary-dim);
      z-index: 999;
      padding: 0 1.5rem;
      align-items: center;
      justify-content: space-between;
    }

    .menu-toggle-btn {
      background: none;
      border: 1px solid var(--primary);
      color: var(--primary);
      padding: 5px 12px;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      cursor: pointer;
    }

    /* --- SIDEBAR --- */
    nav { 
      width: var(--sidebar-width); 
      background: var(--nav-bg); 
      backdrop-filter: blur(15px); 
      border-right: 1px solid var(--primary-dim); 
      display: flex; 
      flex-direction: column; 
      z-index: 1100; 
      transition: transform 0.3s ease;
      flex-shrink: 0;
    }

    .nav-header { padding: 2rem 1.5rem; border-bottom: 1px solid var(--primary-dim); }
    .nav-header h2 { 
        font-family: var(--font-mono); 
        font-weight: 800; 
        font-size: 1.1rem; 
        color: var(--primary); 
        margin: 0;
        letter-spacing: 2px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .nav-header h2::before { content: ""; width: 4px; height: 18px; background: var(--primary); }

    .theme-switcher {
      margin-top: 1.5rem;
      display: flex;
      background: rgba(0, 0, 0, 0.2);
      border: 1px solid var(--primary-dim);
      padding: 2px;
      border-radius: 4px;
    }
    .theme-switcher label {
      flex: 1;
      text-align: center;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      cursor: pointer;
      color: var(--text-muted);
    }
    .theme-switcher input { display: none; }
    .theme-switcher span {
      display: block;
      padding: 10px 0;
      border-radius: 2px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .theme-switcher input:checked + span {
      background: var(--primary-dim);
      color: var(--primary);
    }

    #search { 
        width: 100%; 
        margin-top: 1rem;
        background: rgba(0,0,0,0.1); 
        border: 1px solid var(--primary-dim); 
        padding: 12px; 
        color: var(--primary); 
        font-family: var(--font-mono);
        font-size: 0.75rem;
        outline: none;
    }

    .nav-scroll-area { flex: 1; overflow-y: auto; padding: 1rem; }
    .nav-item { 
        display: block; 
        color: var(--text-muted); 
        text-decoration: none; 
        padding: 12px; 
        font-family: var(--font-mono); 
        font-size: 0.75rem; 
        margin-bottom: 4px;
        border-left: 2px solid transparent;
    }
    .nav-item:hover { color: var(--primary); background: var(--primary-dim); border-left-color: var(--primary); }

    /* --- MAIN CONTENT --- */
    main { 
      flex: 1; 
      padding: 4rem; 
      overflow-y: auto; 
      position: relative; 
      height: 100vh;
      -webkit-overflow-scrolling: touch;
    }
    
    .page-branding { max-width: 800px; margin-bottom: 4rem; position: relative; z-index: 10; }
    .page-branding h1 { 
        font-family: var(--font-mono); 
        font-size: clamp(1.5rem, 5vw, 2.5rem); 
        font-weight: 800; 
        margin: 0; 
        color: var(--primary);
        text-transform: uppercase;
        letter-spacing: -1px;
    }

    #appContainer { 
        display: grid; 
        grid-template-columns: 1fr; 
        gap: 2rem; 
        width: 100%;
        max-width: 850px; 
    }

    /* --- HUD CARD --- */
    .hud-card {
      position: relative;
      padding: clamp(20px, 5vw, 40px);
      background: var(--card-bg);
      /* The shape is applied via inline-style clip-path in JS */
      transition: transform 0.3s ease;
      filter: drop-shadow(0 0 10px rgba(0,0,0,0.2));
    }

    /* THE OUTLINE FIX: We use a pseudo-element with the same clip-path and a slightly larger stroke effect or border */
    .hud-card::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      /* We use the same clip-path and draw an outline using a background + mask technique or just a border if simple */
      background: var(--primary);
      clip-path: var(--outline);
      z-index: -1;
      transform: scale(1.005); /* Slight scale for visual thickness if needed */
      opacity: 0.4;
    }
    
    /* Internal container to clip content to the same shape */
    .hud-content-wrap {
      position: relative;
      z-index: 5;
      clip-path: var(--outline);
    }

    .hud-texture {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image: radial-gradient(var(--primary-dim) 1px, transparent 1px);
      background-size: 14px 14px;
      opacity: 0.15;
    }

    .hud-accent {
      position: absolute;
      pointer-events: none;
      background: var(--primary);
      clip-path: var(--accent-path);
      opacity: 0.6;
      z-index: 6;
    }

    .hud-corner {
      position: absolute;
      pointer-events: none;
      background: var(--primary);
      clip-path: var(--corner-path);
      width: 100%; height: 100%;
      top: 0; left: 0;
      opacity: 0.8;
      z-index: 7;
    }

    .card-header { 
        display: flex; 
        justify-content: space-between; 
        align-items: flex-start; 
        margin-bottom: 1.5rem; 
    }
    .unit-tag { 
        font-family: var(--font-mono); 
        font-size: 0.65rem; 
        color: var(--primary); 
        letter-spacing: 2px;
    }
    .app-title { 
        font-size: clamp(1.1rem, 4vw, 1.5rem); 
        font-weight: 800; 
        margin: 0 0 0.5rem 0; 
        color: var(--text); 
        text-transform: uppercase;
    }
    .summary-content { 
        color: var(--text-muted); 
        font-size: 0.9rem; 
        line-height: 1.6; 
    }

    .launch-btn {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--primary);
        text-decoration: none;
        padding: 10px 20px;
        border: 1px solid var(--primary);
        background: transparent;
        transition: 0.2s;
        flex-shrink: 0;
        margin-left: 10px;
    }
    .launch-btn:hover { 
      background: var(--primary); 
      color: #fff; 
      box-shadow: 0 0 15px var(--primary-glow); 
    }

    @media (max-width: 900px) {
        .mobile-nav-bar { display: flex; }
        
        nav { 
          position: fixed;
          top: 60px; bottom: 0; left: 0;
          transform: translateX(-100%);
          width: 85%;
          max-width: 320px;
          border-right: 1px solid var(--primary-dim);
        }
        
        nav.open { transform: translateX(0); }

        main { padding: 5rem 1rem 2rem 1rem; }
        .page-branding { margin-bottom: 2rem; text-align: center; }
        
        .hud-card { width: 100%; margin: 0 auto; }
        .hud-card:hover { transform: none; }
    }

    .overlay-mask {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.6);
      z-index: 1050;
      backdrop-filter: blur(4px);
    }
    .overlay-mask.active { display: block; }
  </style>
</head>
<body>

  <header class="mobile-nav-bar">
    <div style="font-family: var(--font-mono); font-weight: 800; color: var(--primary); font-size: 0.9rem;">GIZMOS</div>
    <button class="menu-toggle-btn" id="menuToggle">MENU</button>
  </header>

  <div class="overlay-mask" id="sidebarOverlay"></div>

  <nav id="sidebar">
    <div class="nav-header">
      <h2>Gizmos :D</h2>
      
      <div class="theme-switcher">
        <label><input type="radio" name="theme" value="light"><span>Light</span></label>
        <label><input type="radio" name="theme" value="auto"><span>Auto</span></label>
        <label><input type="radio" name="theme" value="dark"><span>Dark</span></label>
      </div>

      <input id="search" type="text" placeholder="QUERY_MODULE..." autocomplete="off" />
    </div>
    <div class="nav-scroll-area" id="projectList">
      {% for name, summary in applications.items() %}
        <a class="nav-item" href="{{ name }}/index.html" data-name="{{ name }}">{{ name }}</a>
      {% endfor %}
    </div>
  </nav>

  <main>
    <div class="page-branding">
      <h1>Gizmos_Registry</h1>
      <p style="color: var(--text-muted); font-family: var(--font-mono); font-size: 0.75rem; margin-top: 0.5rem;">STATUS: TWEAKIN_ACTIVE</p>
    </div>

    <div id="appContainer">
      {% for name, summary in applications.items() %}
        <section class="hud-card" id="card-{{ loop.index }}" data-name="{{ name }}">
          <div class="hud-texture"></div>
          <div class="card-header">
            <span class="unit-tag">REF_NO // {{ 1000 + loop.index }}</span>
            <a class="launch-btn" href="{{ name }}/index.html">Initialize</a>
          </div>
          <h2 class="app-title">{{ name }}</h2>
          <div class="summary-content">
            {{ summary | safe }}
          </div>
        </section>
      {% endfor %}
    </div>
  </main>

  <script src="shared/js/header.js"></script>

  <script>
    /**
     * THEME & NAVIGATION
     */
    function initTheme() {
      const savedTheme = localStorage.getItem('theme') || 'auto';
      const radio = document.querySelector(`input[name="theme"][value="${savedTheme}"]`);
      if (radio) radio.checked = true;

      applyTheme(savedTheme);

      document.querySelectorAll('input[name="theme"]').forEach(input => {
        input.addEventListener('change', (e) => applyTheme(e.target.value));
      });

      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        if (localStorage.getItem('theme') === 'auto') applyTheme('auto');
      });
    }

    function applyTheme(theme) {
      const root = document.documentElement;
      let effectiveTheme = theme;
      if (theme === 'auto') {
        effectiveTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      root.setAttribute('data-theme', effectiveTheme);
      localStorage.setItem('theme', theme);
    }

    function initMobileNav() {
      const menuToggle = document.getElementById('menuToggle');
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebarOverlay');

      const toggle = () => {
        sidebar.classList.toggle('open');
        overlay.classList.toggle('active');
        menuToggle.textContent = sidebar.classList.contains('open') ? 'CLOSE' : 'MENU';
      };

      menuToggle.addEventListener('click', toggle);
      overlay.addEventListener('click', toggle);
    }

    /**
     * PROCEDURAL HUD SYSTEM
     */
    function mulberry32(seed) {
      let t = seed >>> 0;
      return function() {
        t += 0x6D2B79F5;
        let t2 = Math.imul(t ^ t >>> 15, t | 1);
        t2 ^= t2 + Math.imul(t2 ^ t2 >>> 7, t2 | 61);
        return ((t2 ^ t2 >>> 14) >>> 0) / 4294967296;
      };
    }

    function generateHudStylesForElement(el, seedValue) {
      const rng = mulberry32(seedValue);
      const w = el.offsetWidth;
      const h = el.offsetHeight;
      
      const chamfer = () => (rng() > 0.2 ? Math.floor(rng() * 15 + 10) : 0);
      const c = { tl: chamfer(), tr: chamfer(), br: chamfer(), bl: chamfer() };

      const toPct = (px, py) => `${(px / w * 100).toFixed(2)}% ${(py / h * 100).toFixed(2)}%`;

      // Construct Clip Path
      let pts = [];
      pts.push(toPct(c.tl, 0));
      pts.push(toPct(w - c.tr, 0));
      if (c.tr > 0) pts.push(toPct(w, c.tr));
      pts.push(toPct(w, h - c.br));
      if (c.br > 0) pts.push(toPct(w - c.br, h));
      pts.push(toPct(c.bl, h));
      if (c.bl > 0) pts.push(toPct(0, h - c.bl));
      pts.push(toPct(0, c.tl));

      const pathStr = `polygon(${pts.join(', ')})`;
      el.style.setProperty('--outline', pathStr);
      el.style.clipPath = pathStr;

      // Add Corner Accents
      ['tl', 'tr', 'br', 'bl'].forEach(pos => {
        if (rng() > 0.4) {
          const s = 14, g = 3;
          let tri;
          if (pos==='tl') tri = [toPct(g, s+g), toPct(g, g), toPct(s+g, g)];
          if (pos==='tr') tri = [toPct(w-g, s+g), toPct(w-g, g), toPct(w-s-g, g)];
          if (pos==='br') tri = [toPct(w-g, h-s-g), toPct(w-g, h-g), toPct(w-s-g, h-g)];
          if (pos==='bl') tri = [toPct(g, h-s-g), toPct(g, h-g), toPct(s+g, h-g)];

          const div = document.createElement('div');
          div.className = 'hud-corner';
          div.style.setProperty('--corner-path', `polygon(${tri.join(', ')})`);
          el.appendChild(div);
        }
      });

      // Add Edge Accent
      const edge = rng() > 0.5 ? 'top' : 'bottom';
      const aw = w * 0.2, ah = 4, sx = rng() * (w * 0.6) + (w * 0.1);
      let ap;
      if (edge==='top') ap = [toPct(sx, 0), toPct(sx+aw, 0), toPct(sx+aw-4, ah), toPct(sx+4, ah)];
      else ap = [toPct(sx+4, h-ah), toPct(sx+aw-4, h-ah), toPct(sx+aw, h), toPct(sx, h)];

      const acc = document.createElement('div');
      acc.className = 'hud-accent';
      acc.style.setProperty('--accent-path', `polygon(${ap.join(', ')})`);
      el.appendChild(acc);
    }

    function refreshHUD() {
      document.querySelectorAll('.hud-accent, .hud-corner').forEach(e => e.remove());
      document.querySelectorAll('.hud-card').forEach((card, i) => {
        generateHudStylesForElement(card, 777 + (i * 99));
      });
    }

    window.addEventListener('load', () => {
      initTheme();
      initMobileNav();
      refreshHUD();
    });

    window.addEventListener('resize', refreshHUD);

    document.getElementById("search").addEventListener("input", e => {
      const t = e.target.value.toLowerCase();
      document.querySelectorAll(".hud-card, .nav-item").forEach(el => {
        const name = el.dataset.name.toLowerCase();
        el.style.display = name.includes(t) ? "block" : "none";
      });
    });
  </script>
</body>
</html>

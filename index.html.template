<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Web Gizmos | Applications</title>

  <style>
    :root {
      --primary: #6366f1;
      --primary-hover: #4f46e5;
      --bg: #f8fafc;
      --text: #1e293b;
      --text-muted: #64748b;
      --card-bg: #ffffff;
      --card-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
      --sidebar-bg: #1e293b;
      --sidebar-text: #f1f5f9;
      --nav-hover: rgba(255, 255, 255, 0.1);
      --input-bg: #ffffff;
    }

    body.dark {
      --bg: #0f172a;
      --text: #f1f5f9;
      --text-muted: #94a3b8;
      --card-bg: #1e293b;
      --card-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.5);
      --sidebar-bg: #020617;
      --sidebar-text: #e2e8f0;
      --input-bg: #1e293b;
    }

    body {
      margin: 0;
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      display: flex;
      min-height: 100vh;
      transition: background 0.3s ease;
    }

    /* Sidebar Styling */
    nav {
      width: 280px;
      background: var(--sidebar-bg);
      color: var(--sidebar-text);
      padding: 2rem 1.5rem;
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      box-sizing: border-box;
      box-shadow: 4px 0 10px rgba(0,0,0,0.1);
    }

    nav h2 {
      margin: 0 0 1.5rem 0;
      font-size: 1.5rem;
      font-weight: 700;
      background: linear-gradient(to right, #818cf8, #c084fc);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    #search {
      width: 100%;
      padding: 0.75rem 1rem;
      margin-bottom: 2rem;
      border-radius: 0.5rem;
      border: 1px solid rgba(255,255,255,0.1);
      background: rgba(255,255,255,0.05);
      color: white;
      outline: none;
      transition: all 0.2s;
    }

    #search:focus {
      background: rgba(255,255,255,0.1);
      border-color: var(--primary);
    }

    .nav-item {
      display: block;
      color: var(--sidebar-text);
      text-decoration: none;
      padding: 0.75rem 1rem;
      margin: 0.2rem 0;
      border-radius: 0.4rem;
      font-size: 0.9rem;
      transition: all 0.2s;
      opacity: 0.8;
    }

    .nav-item:hover {
      background: var(--nav-hover);
      opacity: 1;
      transform: translateX(5px);
    }

    /* Main Content */
    main {
      flex: 1;
      padding: 3rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    h1 {
      font-size: 2.25rem;
      font-weight: 800;
      margin-bottom: 2rem;
      letter-spacing: -0.025em;
    }

    /* Card Grid */
    .app-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.5rem;
    }

    .app-section {
      background: var(--card-bg);
      padding: 1.75rem;
      border-radius: 1rem;
      box-shadow: var(--card-shadow);
      border: 1px solid rgba(0,0,0,0.05);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      display: flex;
      flex-direction: column;
    }

    .app-section:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1);
    }

    .app-section h2 {
      margin: 0.5rem 0;
      font-size: 1.25rem;
    }

    .app-summary {
      color: var(--text-muted);
      font-size: 0.95rem;
      line-height: 1.5;
      margin-bottom: 1.5rem;
      flex-grow: 1;
    }

    .app-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.6rem 1.2rem;
      background: var(--primary);
      color: white;
      border-radius: 0.5rem;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      transition: background 0.2s;
    }

    .app-link:hover {
      background: var(--primary-hover);
    }

    #themeToggle {
      margin-top: auto;
      padding: 0.75rem;
      background: rgba(255,255,255,0.05);
      color: white;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 0.5rem;
      cursor: pointer;
      font-weight: 500;
      transition: all 0.2s;
    }

    #themeToggle:hover {
      background: rgba(255,255,255,0.1);
    }

    /* Mobile View */
    @media (max-width: 768px) {
      body { flex-direction: column; }
      nav { width: 100%; height: auto; position: relative; }
      main { padding: 1.5rem; }
      .app-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>

<body class="dark"> <nav>
    <h2>Gizmos</h2>
    <input id="search" type="text" placeholder="Search gadgets..." />

    <div id="navLinks">
      {% for name, summary in applications.items() %}
        <a class="nav-item" href="{{ name }}/index.html" data-name="{{ name }}">{{ name }}</a>
      {% endfor %}
    </div>

    <button id="themeToggle">🌓 Switch Theme</button>
  </nav>

  <main>
    <h1>Project Overview</h1>

    <div class="app-grid">
      {% for name, summary in applications.items() %}
        <section class="app-section" data-name="{{ name }}">
          <h2>{{ name }}</h2>
          <div class="app-summary">
            {{ summary | safe }}
          </div>
          <a class="app-link" href="{{ name }}/index.html">Launch Application</a>
        </section>
      {% endfor %}
    </div>
  </main>

  <script>
    const search = document.getElementById("search");
    const navItems = document.querySelectorAll(".nav-item");
    const sections = document.querySelectorAll(".app-section");

    search.addEventListener("input", () => {
      const q = search.value.toLowerCase();
      navItems.forEach(item => {
        item.style.display = item.dataset.name.toLowerCase().includes(q) ? "block" : "none";
      });
      sections.forEach(sec => {
        sec.style.display = sec.dataset.name.toLowerCase().includes(q) ? "flex" : "none";
      });
    });

    const toggle = document.getElementById("themeToggle");
    toggle.addEventListener("click", () => {
      document.body.classList.toggle("dark");
    });
  </script>
</body>
</html>

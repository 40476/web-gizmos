<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Applications Overview</title>
  <style>
    :root {
      --primary: #01ff70;
      --bg: #111;
      --nav-bg: #000;
      --card-bg: #222;
      --text: #fafafa;
      --text-muted: #bbb;
      --border: #444;
      --code-bg: #333;
    }

    body.theme-light {
      --primary: #0074d9;
      --bg: #f4f4f4;
      --nav-bg: #e0e0e0;
      --card-bg: #ffffff;
      --text: #111;
      --text-muted: #444;
      --border: #ccc;
      --code-bg: #eee;
    }

    @media (prefers-color-scheme: light) {
      body.theme-auto {
        --primary: #0074d9;
        --bg: #f4f4f4;
        --nav-bg: #e0e0e0;
        --card-bg: #ffffff;
        --text: #111;
        --text-muted: #444;
        --border: #ccc;
        --code-bg: #eee;
      }
    }

    *, *::before, *::after { box-sizing: border-box; }

    html, body { 
      margin: 0; padding: 0; width: 100%; overflow-x: hidden;
      font-family: "Courier New", Courier, monospace;
    }

    body { background: var(--bg); color: var(--text); display: flex; min-height: 100vh; }

    /* --- SIDEBAR --- */
    nav {
      width: 280px;
      min-width: 280px;
      background: var(--nav-bg);
      padding: 1.5rem;
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      z-index: 100;
    }

    /* Desktop Navigation: Always Visible */
    .nav-menu summary { list-style: none; color: var(--primary); font-weight: bold; padding: 10px 0; }
    .nav-menu summary::-webkit-details-marker { display: none; }
    
    /* Mobile-only toggle indicator */
    .toggle-indicator { display: none; transition: transform 0.3s; }
    details[open] .toggle-indicator { transform: rotate(90deg); }

    .nav-items-container {
      margin-top: 10px;
      max-height: 70vh;
      overflow-y: auto;
    }

    .nav-item {
      display: block;
      color: var(--text-muted);
      text-decoration: none;
      padding: 8px 0;
      font-size: 0.9rem;
      border-bottom: 1px solid transparent;
    }
    .nav-item:hover { color: var(--primary); border-bottom: 1px solid var(--border); }

    /* --- MAIN CONTENT --- */
    main { 
      flex: 1; 
      padding: 2rem; 
      width: 100%;
    }

    /* Fixed Width Filter Bar */
    .filter-container {
      max-width: 800px;
      margin: 0 auto 2rem auto;
    }

    #search {
      width: 100%;
      padding: 12px;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--primary);
      border-radius: 4px;
      outline: none;
    }

    /* Fixed Width Project Cards */
    .app-section {
      background: var(--card-bg);
      padding: 2rem;
      margin: 0 auto 3rem auto;
      max-width: 800px; /* Card width constraint */
      border-radius: 8px;
      border: 1px solid var(--border);
    }

    /* --- RESPONSIVE / MOBILE --- */
    @media (max-width: 850px) {
      body { flex-direction: column; }
      nav { 
        width: 100%; min-width: 100%; height: auto; 
        position: relative; border-right: none; border-bottom: 1px solid var(--border); 
      }
      .toggle-indicator { display: inline-block; margin-right: 8px; }
      .nav-menu summary { border-bottom: 1px dashed var(--border); }
      
      /* Force Desktop sidebar to be a real accordion on mobile */
      .nav-menu:not([open]) .nav-items-container { display: none; }
    }

    /* On Desktop, we force the details to stay open and hide the toggle */
    @media (min-width: 851px) {
      .nav-menu { pointer-events: none; } /* Disable clicking on Desktop */
      .nav-menu .nav-items-container { display: block !important; }
      .nav-menu summary { cursor: default; }
    }

    /* Theme Controls */
    .theme-controls { font-size: 0.8rem; margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--border); }
    .theme-controls label { display: block; margin: 5px 0; cursor: pointer; }

    /* Utility */
    .highlight { background: var(--primary); color: #000; font-weight: bold; }
    pre { background: var(--code-bg); padding: 1rem; overflow-x: auto; border-left: 4px solid var(--primary); }
    code { color: var(--primary); }
  </style>

  <noscript>
    <style>#search, .theme-controls { display: none !important; }</style>
  </noscript>
</head>
<body class="theme-auto">

  <nav>
    <h2 style="color: var(--primary); margin: 0 0 1rem 0;">GIZMOS</h2>
    
    <details class="nav-menu" open>
      <summary><span class="toggle-indicator">▶</span>PROJECTS</summary>
      <div class="nav-items-container">
        {% for name, summary in applications.items() %}
          <a class="nav-item" href="{{ name }}/index.html" data-name="{{ name }}">> {{ name }}</a>
        {% endfor %}
      </div>
    </details>

    <div class="theme-controls">
      <strong>UI THEME</strong>
      <label><input type="radio" name="theme" value="theme-dark"> DARK</label>
      <label><input type="radio" name="theme" value="theme-light"> LIGHT</label>
      <label><input type="radio" name="theme" value="theme-auto" checked> AUTO</label>
    </div>
  </nav>

  <main>
    <h1 style="text-align: center; margin-bottom: 2rem;">web-gizmos</h1>

    <div class="filter-container">
        <input id="search" type="text" placeholder="Filter gizmos..." autocomplete="off" />
    </div>

    <div id="appContainer">
      {% for name, summary in applications.items() %}
        <section class="app-section" id="section-{{ name }}" data-name="{{ name }}">
          <a style="text-decoration: none; color: var(--primary); font-size: 0.7rem; font-weight: bold;" href="{{ name }}/index.html">[ RUN APPLICATION ]</a>
          <h2 class="app-title">{{ name }}</h2>
          <div class="summary-content">
            {{ summary | safe }}
          </div>
        </section>
      {% endfor %}
    </div>

    <footer style="text-align: center; margin-top: 4rem; padding: 2rem; font-size: 0.8rem; border-top: 1px solid var(--border); opacity: 0.5;">
      <p>Last Sync: {{ last_updated }}</p>
    </footer>
  </main>

  <script>
    // Theme Persistance
    const radios = document.querySelectorAll('input[name="theme"]');
    const setTheme = (t) => {
      document.body.className = t;
      localStorage.setItem("gizmo-ui-pref", t);
    };
    radios.forEach(r => r.addEventListener("change", e => setTheme(e.target.value)));
    const saved = localStorage.getItem("gizmo-ui-pref") || "theme-auto";
    setTheme(saved);
    const checkedRadio = document.querySelector(`input[value="${saved}"]`);
    if(checkedRadio) checkedRadio.checked = true;

    // Filter logic with Highlighting
    const search = document.getElementById("search");
    const menu = document.querySelector(".nav-menu");

    search.addEventListener("input", e => {
      const term = e.target.value.toLowerCase();
      
      // Expand menu on mobile if user starts searching
      if (term.length > 0 && window.innerWidth <= 850) menu.open = true;

      document.querySelectorAll(".app-section").forEach(sec => {
        const name = sec.dataset.name.toLowerCase();
        const title = sec.querySelector(".app-title");
        const isMatch = name.includes(term);
        
        sec.style.display = isMatch ? "block" : "none";
        
        if (isMatch && term.length > 0) {
          const regex = new RegExp(`(${term})`, "gi");
          title.innerHTML = sec.dataset.name.replace(regex, '<span class="highlight">$1</span>');
        } else {
          title.textContent = sec.dataset.name;
        }
      });

      document.querySelectorAll(".nav-item").forEach(item => {
        item.style.display = item.dataset.name.toLowerCase().includes(term) ? "block" : "none";
      });
    });
  </script>
</body>
</html>

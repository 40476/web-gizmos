<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Applications Overview</title>
  <style>
    /* 1. The Variable Engine */
    :root {
      --primary: #01ff70;
      --bg: #111;
      --nav-bg: #000;
      --card-bg: #222;
      --text: #fafafa;
      --text-muted: #bbb;
      --border: #444;
      --code-bg: #333;
    }

    body.theme-light {
      --primary: #0074d9;
      --bg: #f4f4f4;
      --nav-bg: #e0e0e0;
      --card-bg: #ffffff;
      --text: #111;
      --text-muted: #444;
      --border: #ccc;
      --code-bg: #eee;
    }

    @media (prefers-color-scheme: light) {
      body.theme-auto {
        --primary: #0074d9;
        --bg: #f4f4f4;
        --nav-bg: #e0e0e0;
        --card-bg: #ffffff;
        --text: #111;
        --text-muted: #444;
        --border: #ccc;
        --code-bg: #eee;
      }
    }

    /* 2. Global Resets to fix "Larger than Screen" issues */
    *, *::before, *::after { box-sizing: border-box; }

    html, body { 
      margin: 0; 
      padding: 0;
      width: 100%;
      overflow-x: hidden; /* Hard stop for horizontal scrolling */
      font-family: "Courier New", Courier, monospace;
    }

    body { 
      background: var(--bg); 
      color: var(--text); 
      display: flex; 
      min-height: 100vh; 
      transition: background 0.2s, color 0.2s; 
    }

    /* 3. Sidebar Styling */
    nav {
      width: 280px;
      min-width: 280px;
      background: var(--nav-bg); /* Use variable here */
      padding: 1.5rem;
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      z-index: 100;
      transition: background 0.2s;
    }

    /* Collapsible Navigation */
    details.nav-menu { margin-top: 1rem; flex-grow: 1; }
    details.nav-menu summary { 
      cursor: pointer; 
      color: var(--primary); 
      font-weight: bold; 
      list-style: none;
      padding: 10px 0;
      border-bottom: 1px dashed var(--border);
    }
    details.nav-menu summary::-webkit-details-marker { display: none; }
    
    .nav-items-container {
      margin-top: 10px;
      max-height: 60vh;
      overflow-y: auto;
    }

    .nav-item {
      display: block;
      color: var(--text-muted);
      text-decoration: none;
      padding: 8px 0;
      font-size: 0.9rem;
    }
    .nav-item:hover { color: var(--primary); }

    /* 4. Main Content Fixes */
    main { 
      flex: 1; 
      padding: 2rem; 
      max-width: 100%; /* Fix width overflow */
      width: 100%;
    }

    .app-section {
      background: var(--card-bg);
      padding: 2rem;
      margin: 0 auto 3rem auto;
      max-width: 800px; /* Centered readable cards */
      border-radius: 8px;
      border: 1px solid var(--border);
      transition: background 0.2s;
    }

    /* 5. Mobile Adjustments */
    @media (max-width: 850px) {
      body { flex-direction: column; }
      nav { 
        width: 100%; 
        min-width: 100%; 
        height: auto; 
        position: relative; 
        border-right: none; 
        border-bottom: 1px solid var(--border); 
      }
      .nav-items-container { max-height: 40vh; }
    }

    /* Utility */
    #search {
      width: 100%;
      padding: 12px;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--primary);
      border-radius: 4px;
      margin-bottom: 1rem;
    }
    .highlight { background: var(--primary); color: #000; font-weight: bold; }
    .theme-controls { font-size: 0.8rem; margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border); }
    .theme-controls label { display: block; margin: 5px 0; cursor: pointer; }
    pre { background: var(--code-bg); padding: 1rem; overflow-x: auto; border-left: 4px solid var(--primary); }
    code { color: var(--primary); }
  </style>

  <noscript>
    <style>#search, .theme-controls { display: none !important; }</style>
  </noscript>
</head>
<body class="theme-auto">

  <nav>
    <h2 style="color: var(--primary); margin: 0 0 1rem 0;">GIZMOS</h2>
    
    <input id="search" type="text" placeholder="Filter..." autocomplete="off" />

    <details class="nav-menu">
      <summary>PROJECTS [ + ]</summary>
      <div class="nav-items-container">
        {% for name, summary in applications.items() %}
          <a class="nav-item" href="{{ name }}/index.html" data-name="{{ name }}">> {{ name }}</a>
        {% endfor %}
      </div>
    </details>

    <div class="theme-controls">
      <strong>APPEARANCE</strong>
      <label><input type="radio" name="theme" value="theme-dark"> DARK</label>
      <label><input type="radio" name="theme" value="theme-light"> LIGHT</label>
      <label><input type="radio" name="theme" value="theme-auto" checked> AUTO</label>
    </div>
  </nav>

  <main>
    <h1 style="text-align: center;">web-gizmos</h1>

    <div id="appContainer">
      {% for name, summary in applications.items() %}
        <section class="app-section" id="section-{{ name }}" data-name="{{ name }}">
          <a style="text-decoration: none; color: var(--primary); font-size: 0.7rem;" href="{{ name }}/index.html">[ LAUNCH ]</a>
          <h2 class="app-title">{{ name }}</h2>
          <div class="summary-content">
            {{ summary | safe }}
          </div>
        </section>
      {% endfor %}
    </div>

    <footer style="text-align: center; margin-top: 4rem; padding: 2rem; font-size: 0.8rem; border-top: 1px solid var(--border);">
      <p>Registry Sync: {{ last_updated }}</p>
    </footer>
  </main>

  <script>
    // Theme Engine
    const radios = document.querySelectorAll('input[name="theme"]');
    const setTheme = (t) => {
      document.body.className = t;
      localStorage.setItem("gizmo-pref", t);
    };
    radios.forEach(r => r.addEventListener("change", e => setTheme(e.target.value)));
    const saved = localStorage.getItem("gizmo-pref") || "theme-auto";
    setTheme(saved);
    document.querySelector(`input[value="${saved}"]`).checked = true;

    // Search + Highlighting + Auto-Expand
    const search = document.getElementById("search");
    const menu = document.querySelector(".nav-menu");

    search.addEventListener("input", e => {
      const term = e.target.value.toLowerCase();
      
      // Auto-open menu when searching
      if (term.length > 0) menu.open = true;

      document.querySelectorAll(".app-section").forEach(sec => {
        const name = sec.dataset.name.toLowerCase();
        const title = sec.querySelector(".app-title");
        const match = name.includes(term);
        sec.style.display = match ? "block" : "none";
        if (match && term.length > 0) {
          title.innerHTML = sec.dataset.name.replace(new RegExp(`(${term})`, "gi"), '<span class="highlight">$1</span>');
        } else {
          title.textContent = sec.dataset.name;
        }
      });

      document.querySelectorAll(".nav-item").forEach(item => {
        item.style.display = item.dataset.name.toLowerCase().includes(term) ? "block" : "none";
      });
    });
  </script>
</body>
</html>

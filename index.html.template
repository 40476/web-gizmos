<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Applications Overview</title>
  <style>
    :root {
      --primary: #01ff70;
      --bg: #111;
      --nav-bg: #000;
      --card-bg: #222;
      --text: #fafafa;
      --text-muted: #bbb;
      --border: #444;
      --code-bg: #333;
    }

    body.theme-light {
      --primary: #0074d9;
      --bg: #f4f4f4;
      --nav-bg: #e0e0e0;
      --card-bg: #ffffff;
      --text: #111;
      --text-muted: #444;
      --border: #ccc;
      --code-bg: #eee;
    }

    @media (prefers-color-scheme: light) {
      body.theme-auto {
        --primary: #0074d9;
        --bg: #f4f4f4;
        --nav-bg: #e0e0e0;
        --card-bg: #ffffff;
        --text: #111;
        --text-muted: #444;
        --border: #ccc;
        --code-bg: #eee;
      }
    }

    *, *::before, *::after { box-sizing: border-box; }

    html, body { 
      margin: 0; padding: 0; width: 100%; overflow-x: hidden;
      font-family: "Courier New", Courier, monospace;
    }

    body { background: var(--bg); color: var(--text); display: flex; min-height: 100vh; }

    /* --- SIDEBAR --- */
    nav {
      width: 300px;
      min-width: 300px;
      background: var(--nav-bg);
      padding: 1.5rem;
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      z-index: 100;
      transition: background 0.2s;
    }

    nav h2 { color: var(--primary); margin: 0 0 1.5rem 0; font-size: 1.4rem; }

    /* Search Bar in Sidebar */
    .search-container { margin-bottom: 1.5rem; }
    #search {
      width: 100%;
      padding: 10px;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--primary);
      border-radius: 4px;
      outline: none;
      font-family: inherit;
    }

    /* Projects List Logic */
    .nav-menu summary { 
      list-style: none; 
      color: var(--primary); 
      font-weight: bold; 
      padding: 10px 0;
      cursor: pointer;
    }
    .nav-menu summary::-webkit-details-marker { display: none; }
    
    .toggle-indicator { display: inline-block; margin-right: 8px; transition: transform 0.2s; }
    details[open] .toggle-indicator { transform: rotate(90deg); }

    .nav-items-container {
      margin-top: 10px;
      max-height: 60vh;
      overflow-y: auto;
      padding-right: 5px;
    }

    .nav-item {
      display: block;
      color: var(--text-muted);
      text-decoration: none;
      padding: 8px 0;
      font-size: 0.85rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .nav-item:hover { color: var(--primary); }

    /* --- MAIN CONTENT --- */
    main { 
      flex: 1; 
      padding: 2rem; 
      width: 100%;
      overflow-y: auto;
    }

    .app-section {
      background: var(--card-bg);
      padding: 2rem;
      margin: 0 auto 3rem auto;
      max-width: 800px; /* Constrains card width */
      width: 100%;
      border-radius: 8px;
      border: 1px solid var(--border);
    }

    /* --- RESPONSIVE BEHAVIOR --- */
    
    /* Desktop: List is always visible, Summary is just a label */
    @media (min-width: 851px) {
      .nav-menu { display: block !important; }
      .nav-menu summary { cursor: default; pointer-events: none; }
      .nav-menu .toggle-indicator { display: none; }
      .nav-items-container { display: block !important; }
    }

    /* Mobile: List is a collapsible drawer */
    @media (max-width: 850px) {
      body { flex-direction: column; }
      nav { 
        width: 100%; min-width: 100%; height: auto; 
        position: relative; border-right: none; border-bottom: 1px solid var(--border); 
        padding: 1rem;
      }
      .nav-items-container { max-height: 40vh; }
      .nav-menu summary { border-bottom: 1px dashed var(--border); }
    }

    /* Theme Controls */
    .theme-controls { font-size: 0.75rem; margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--border); }
    .theme-controls label { display: block; margin: 5px 0; cursor: pointer; }

    /* Utility */
    .highlight { background: var(--primary); color: #000; font-weight: bold; }
    pre { background: var(--code-bg); padding: 1rem; overflow-x: auto; border-left: 4px solid var(--primary); font-size: 0.85rem; }
    code { color: var(--primary); }
  </style>

  <noscript>
    <style>#search, .theme-controls { display: none !important; }</style>
  </noscript>
</head>
<body class="theme-auto">

  <nav>
    <h2>GIZMOS</h2>
    
    <div class="search-container">
      <input id="search" type="text" placeholder="Search..." autocomplete="off" />
    </div>

    <details class="nav-menu" open>
      <summary><span class="toggle-indicator">▶</span>PROJECTS</summary>
      <div class="nav-items-container" id="navList">
        {% for name, summary in applications.items() %}
          <a class="nav-item" href="{{ name }}/index.html" data-name="{{ name }}">> {{ name }}</a>
        {% endfor %}
      </div>
    </details>

    <div class="theme-controls">
      <strong>APPEARANCE</strong>
      <label><input type="radio" name="theme" value="theme-dark"> DARK</label>
      <label><input type="radio" name="theme" value="theme-light"> LIGHT</label>
      <label><input type="radio" name="theme" value="theme-auto" checked> AUTO</label>
    </div>
  </nav>

  <main>
    <h1 style="text-align: center; margin-bottom: 3rem;">web-gizmos</h1>

    <div id="appContainer">
      {% for name, summary in applications.items() %}
        <section class="app-section" id="section-{{ name }}" data-name="{{ name }}">
          <a style="text-decoration: none; color: var(--primary); font-size: 0.7rem; font-weight: bold;" href="{{ name }}/index.html">[ RUN GIZMO ]</a>
          <h2 class="app-title">{{ name }}</h2>
          <div class="summary-content">
            {{ summary | safe }}
          </div>
        </section>
      {% endfor %}
    </div>

    <footer style="text-align: center; margin-top: 4rem; padding: 2rem; font-size: 0.8rem; border-top: 1px solid var(--border); opacity: 0.4;">
      <p>Last Sync: {{ last_updated }}</p>
    </footer>
  </main>

  <script>
    // Theme Engine
    const radios = document.querySelectorAll('input[name="theme"]');
    const setTheme = (t) => {
      document.body.className = t;
      localStorage.setItem("gizmo-theme-key", t);
    };
    radios.forEach(r => r.addEventListener("change", e => setTheme(e.target.value)));
    const saved = localStorage.getItem("gizmo-theme-key") || "theme-auto";
    setTheme(saved);
    const checked = document.querySelector(`input[value="${saved}"]`);
    if(checked) checked.checked = true;

    // Filter Logic
    const search = document.getElementById("search");
    const menu = document.querySelector(".nav-menu");

    search.addEventListener("input", e => {
      const term = e.target.value.toLowerCase();
      
      // Auto-expand mobile drawer if searching
      if (term.length > 0 && window.innerWidth <= 850) menu.open = true;

      document.querySelectorAll(".app-section").forEach(sec => {
        const name = sec.dataset.name.toLowerCase();
        const titleEl = sec.querySelector(".app-title");
        const match = name.includes(term);
        
        sec.style.display = match ? "block" : "none";
        
        if (match && term.length > 0) {
          const regex = new RegExp(`(${term})`, "gi");
          titleEl.innerHTML = sec.dataset.name.replace(regex, '<span class="highlight">$1</span>');
        } else {
          titleEl.textContent = sec.dataset.name;
        }
      });

      document.querySelectorAll(".nav-item").forEach(item => {
        item.style.display = item.dataset.name.toLowerCase().includes(term) ? "block" : "none";
      });
    });
  </script>
</body>
</html>

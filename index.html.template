<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Applications Overview</title>
  <style>
    :root {
      --primary: #01ff70;
      --bg: #111;
      --nav-bg: #000;
      --card-bg: #222;
      --text: #fafafa;
      --text-muted: #bbb;
      --border: #444;
      --code-bg: #333;
    }

    body.theme-light {
      --primary: #0074d9;
      --bg: #f4f4f4;
      --nav-bg: #e8e8e8;
      --card-bg: #ffffff;
      --text: #111;
      --text-muted: #444;
      --border: #ccc;
      --code-bg: #eee;
    }

    @media (prefers-color-scheme: light) {
      body.theme-auto {
        --primary: #0074d9;
        --bg: #f4f4f4;
        --nav-bg: #e8e8e8;
        --card-bg: #ffffff;
        --text: #111;
        --text-muted: #444;
        --border: #ccc;
        --code-bg: #eee;
      }
    }

    *, *::before, *::after { box-sizing: border-box; }

    /* Fix for "too tall" and "not sticky" */
    html, body { 
      margin: 0; padding: 0; 
      height: 100%; 
      width: 100%;
      overflow: hidden; /* We scroll the main element, not the body */
      font-family: "Courier New", Courier, monospace;
    }

    body { 
      background: var(--bg); 
      color: var(--text); 
      display: flex; 
      /* Re-enabling the smooth theme fade */
      transition: background 0.4s ease, color 0.4s ease, border-color 0.4s ease; 
    }

    /* --- SIDEBAR --- */
    nav {
      width: 300px;
      min-width: 300px;
      background: var(--nav-bg);
      padding: 1.5rem;
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      height: 100%; /* Fill the fixed body height */
      transition: background 0.4s ease, border-color 0.4s ease;
    }

    nav h2 { color: var(--primary); margin: 0 0 1.5rem 0; font-size: 1.4rem; }

    .search-wrapper { position: relative; margin-bottom: 1.5rem; }
    #search {
      width: 100%;
      padding: 10px 35px 10px 10px;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--primary);
      border-radius: 4px;
      outline: none;
      transition: all 0.4s ease;
    }
    #clearSearch {
      position: absolute;
      right: 10px; top: 50%; transform: translateY(-50%);
      background: none; border: none; color: var(--text-muted);
      cursor: pointer; display: none; font-weight: bold;
    }

    .nav-menu summary { 
      list-style: none; color: var(--primary); font-weight: bold; 
      padding: 10px 0; cursor: pointer;
    }
    .nav-menu summary::-webkit-details-marker { display: none; }
    .toggle-indicator { display: inline-block; margin-right: 8px; transition: transform 0.2s; }
    details[open] .toggle-indicator { transform: rotate(90deg); }

    .nav-items-container {
      margin-top: 10px;
      flex-grow: 1;
      overflow-y: auto;
    }

    .nav-item {
      display: block;
      color: var(--text-muted);
      text-decoration: none;
      padding: 8px 0;
      font-size: 0.85rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      transition: color 0.2s;
    }
    .nav-item:hover { color: var(--primary); }

    /* --- MAIN CONTENT (The scrollable part) --- */
    main { 
      flex: 1; 
      padding: 2rem;
      overflow-y: auto; /* This makes the sidebar "effectively" sticky */
      min-width: 0;
      transition: background 0.4s ease;
    }

    .app-section {
      background: var(--card-bg);
      padding: 2.5rem;
      margin: 0 auto 3rem auto;
      max-width: 800px;
      border-radius: 8px;
      border: 1px solid var(--border);
      transition: background 0.4s ease, border-color 0.4s ease;
    }

    /* --- MOBILE OVERRIDES --- */
    @media (max-width: 850px) {
      html, body { overflow: auto; height: auto; }
      body { flex-direction: column; }
      nav { width: 100%; min-width: 100%; height: auto; border-right: none; border-bottom: 1px solid var(--border); }
      main { overflow-y: visible; }
    }

    /* Desktop constraints */
    @media (min-width: 851px) {
      .nav-menu { display: block !important; }
      .nav-menu summary { cursor: default; pointer-events: none; }
      .nav-menu .toggle-indicator { display: none; }
    }

    .theme-controls { font-size: 0.75rem; margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--border); }
    .theme-controls label { display: block; margin: 5px 0; cursor: pointer; }
    .highlight { background: var(--primary); color: #000; font-weight: bold; padding: 0 2px; }
    pre { background: var(--code-bg); padding: 1rem; overflow-x: auto; border-left: 4px solid var(--primary); font-size: 0.85rem; transition: background 0.4s ease;}
    code { color: var(--primary); }
  </style>
</head>
<body class="theme-auto">

  <nav>
    <h2>GIZMOS</h2>
    <div class="search-wrapper">
      <input id="search" type="text" placeholder="Search..." autocomplete="off" />
      <button id="clearSearch">×</button>
    </div>

    <details class="nav-menu" open>
      <summary><span class="toggle-indicator">▶</span>PROJECTS</summary>
      <div class="nav-items-container">
        {% for name, summary in applications.items() %}
          <a class="nav-item" href="{{ name }}/index.html" data-name="{{ name }}">> {{ name }}</a>
        {% endfor %}
      </div>
    </details>

    <div class="theme-controls">
      <strong>APPEARANCE</strong>
      <label><input type="radio" name="theme" value="theme-dark"> DARK</label>
      <label><input type="radio" name="theme" value="theme-light"> LIGHT</label>
      <label><input type="radio" name="theme" value="theme-auto" checked> AUTO</label>
    </div>
  </nav>

  <main>
    <h1 style="text-align: center; margin-bottom: 3rem;">web-gizmos</h1>
    <div id="appContainer">
      {% for name, summary in applications.items() %}
        <section class="app-section" id="section-{{ name }}" data-name="{{ name }}">
          <a style="text-decoration: none; color: var(--primary); font-size: 0.7rem; font-weight: bold;" href="{{ name }}/index.html">[ RUN GIZMO ]</a>
          <h2 class="app-title">{{ name }}</h2>
          <div class="summary-content">
            {{ summary | safe }}
          </div>
        </section>
      {% endfor %}
    </div>
    <footer style="text-align: center; margin-top: 4rem; padding: 2rem; font-size: 0.8rem; border-top: 1px solid var(--border); opacity: 0.4;">
      <p>Registry Sync: {{ last_updated }}</p>
    </footer>
  </main>

  <script>
    // Theme Engine with persist fade
    const radios = document.querySelectorAll('input[name="theme"]');
    const setTheme = (t) => {
      document.body.className = t;
      localStorage.setItem("gizmo-pref-v3", t);
    };
    radios.forEach(r => r.addEventListener("change", e => setTheme(e.target.value)));
    const saved = localStorage.getItem("gizmo-pref-v3") || "theme-auto";
    setTheme(saved);
    const radioEl = document.querySelector(`input[value="${saved}"]`);
    if(radioEl) radioEl.checked = true;

    // Filter Logic
    const search = document.getElementById("search");
    const clearBtn = document.getElementById("clearSearch");
    const menu = document.querySelector(".nav-menu");

    function doFilter(val) {
      const term = val.toLowerCase();
      clearBtn.style.display = term.length > 0 ? "block" : "none";
      if (term.length > 0 && window.innerWidth <= 850) menu.open = true;

      document.querySelectorAll(".app-section").forEach(sec => {
        const name = sec.dataset.name.toLowerCase();
        const titleEl = sec.querySelector(".app-title");
        const match = name.includes(term);
        sec.style.display = match ? "block" : "none";
        if (match && term.length > 0) {
          titleEl.innerHTML = sec.dataset.name.replace(new RegExp(`(${term})`, "gi"), '<span class="highlight">$1</span>');
        } else {
          titleEl.textContent = sec.dataset.name;
        }
      });
      document.querySelectorAll(".nav-item").forEach(item => {
        item.style.display = item.dataset.name.toLowerCase().includes(term) ? "block" : "none";
      });
    }

    search.addEventListener("input", e => doFilter(e.target.value));
    clearBtn.addEventListener("click", () => {
      search.value = "";
      doFilter("");
      search.focus();
    });
  </script>
</body>
</html>

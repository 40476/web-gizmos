<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gizmos</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --primary: #12a8ff;
      --primary-glow: rgba(18, 168, 255, 0.5);
      --primary-dim: rgba(18, 168, 255, 0.15);
      --bg: #020b12;
      --card-bg: rgba(4, 22, 34, 0.85);
      --nav-bg: rgba(4, 22, 34, 0.95);
      --text: #ececec;
      --text-muted: #5a7b8f;
      --font-main: 'Inter', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
      --sidebar-width: 300px;
    }

    [data-theme="light"] {
      --bg: #f0f4f8;
      --card-bg: rgba(255, 255, 255, 0.9);
      --nav-bg: rgba(235, 240, 245, 0.95);
      --text: #1a2a3a;
      --text-muted: #5a7b8f;
      --primary-dim: rgba(18, 168, 255, 0.1);
    }

    * { box-sizing: border-box; }
    html, body { 
      margin: 0; padding: 0; 
      height: 100vh; width: 100%; 
      font-family: var(--font-main); 
      background: var(--bg); 
      color: var(--text); 
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    body { 
      display: flex; 
      background-image: 
        radial-gradient(circle at 20% 20%, var(--primary-dim) 0%, transparent 40%),
        radial-gradient(circle at 80% 80%, var(--primary-dim) 0%, transparent 40%);
      overflow: hidden;
      padding-top: 50px; /* Space for the fixed API header */
    }

    /* --- SIDEBAR --- */
    nav { 
      width: var(--sidebar-width); 
      background: var(--nav-bg); 
      backdrop-filter: blur(15px); 
      border-right: 1px solid var(--primary-dim); 
      display: flex; 
      flex-direction: column; 
      z-index: 1100; 
      transition: transform 0.3s ease;
    }

    .nav-header { padding: 2rem 1.5rem; border-bottom: 1px solid var(--primary-dim); }
    .nav-header h2 { 
        font-family: var(--font-mono); 
        font-weight: 800; 
        font-size: 1.1rem; 
        color: var(--primary); 
        margin: 0;
        letter-spacing: 2px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .nav-header h2::before { content: ""; width: 4px; height: 18px; background: var(--primary); }

    /* Theme Switcher Moved to Bottom */
    .nav-footer {
      padding: 1.5rem;
      border-top: 1px solid var(--primary-dim);
    }

    .theme-switcher {
      display: flex;
      background: rgba(0, 0, 0, 0.2);
      border: 1px solid var(--primary-dim);
      padding: 2px;
      border-radius: 4px;
    }
    .theme-switcher label {
      flex: 1;
      text-align: center;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      padding: 2px;
      cursor: pointer;
      color: var(--text-muted);
      transition: 0.2s;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .theme-switcher input { display: none; }
    .theme-switcher input:checked + span {
      background: var(--primary-dim);
      color: var(--primary);
      box-shadow: inset 0 0 8px var(--primary-dim);
    }
    .theme-switcher span {
      display: block;
      width: 100%;
      height: 100%;
      padding: 10px 0;
      border-radius: 2px;
    }

    .nav-scroll-area { flex: 1; overflow-y: auto; padding: 1rem; }
    .nav-item { 
        display: block; 
        color: var(--text-muted); 
        text-decoration: none; 
        padding: 10px 12px; 
        font-family: var(--font-mono); 
        font-size: 0.75rem; 
        margin-bottom: 4px;
        transition: 0.2s;
    }
    .nav-item:hover { color: var(--primary); background: var(--primary-dim); }

    /* --- MAIN CONTENT --- */
    main { flex: 1; padding: 4rem; overflow-y: auto; position: relative; }
    .header-area { max-width: 800px; margin-bottom: 4rem; }
    .header-area h1 { 
        font-family: var(--font-mono); 
        font-size: 2.5rem; 
        font-weight: 800; 
        margin: 0; 
        color: var(--primary);
        text-transform: uppercase;
        letter-spacing: -1px;
    }

    #appContainer { display: grid; grid-template-columns: 1fr; gap: 2.5rem; max-width: 850px; }

    .hud-card {
      position: relative;
      padding: 40px;
      background: var(--card-bg);
      clip-path: var(--outline, polygon(0 0, 100% 0, 100% 100%, 0 100%));
      border: none; 
      transition: transform 0.3s ease;
    }
    
    .hud-card::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      clip-path: var(--outline);
      background: var(--primary-dim);
      padding: 1px;
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      z-index: 30;
      transition: background 0.3s ease, opacity 0.3s ease;
    }
    
    .hud-card:hover::before { background: var(--primary); opacity: 1; }
    .hud-card:hover { transform: translateX(10px); }
    .hud-card .hud-texture {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image: radial-gradient(var(--primary-dim) 1px, transparent 1px);
      background-size: 14px 14px;
      opacity: 0.2;
    }

    .hud-accent, .hud-corner {
      position: absolute;
      pointer-events: none;
      background: var(--primary);
      width: 100%; height: 100%;
      top: 0; left: 0;
    }
    .hud-accent { clip-path: var(--accent-path); opacity: 0.6; }
    .hud-corner { clip-path: var(--corner-path); opacity: 0.8; }

    .card-header { 
        display: flex; justify-content: space-between; align-items: center; 
        margin-bottom: 1.5rem; position: relative; z-index: 20;
    }
    .unit-tag { font-family: var(--font-mono); font-size: 0.65rem; color: var(--primary); letter-spacing: 2px; }
    .app-title { font-size: 1.5rem; font-weight: 800; margin: 0; color: var(--text); text-transform: uppercase; position: relative; z-index: 20; }
    .summary-content { color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; position: relative; z-index: 20; }

    .launch-btn {
        font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700;
        text-transform: uppercase; color: var(--primary); text-decoration: none;
        padding: 8px 16px; border: 1px solid var(--primary); background: transparent; transition: 0.2s;
    }
    .launch-btn:hover { background: var(--primary); color: #fff; box-shadow: 0 0 15px var(--primary-glow); }

    @media (max-width: 900px) {
        nav { 
          position: fixed; top: 50px; bottom: 0; left: 0;
          transform: translateX(-100%); width: 85%; max-width: 320px;
        }
        nav.open { transform: translateX(0); }
        main { padding: 4rem 1.5rem 2rem 1.5rem; }
    }
  </style>
</head>
<body>

  <nav id="sidebar">
    <div class="nav-header">
      <h2>Gizmos :D</h2>
    </div>
    
    <div class="nav-scroll-area" id="projectList">
      {% for name, summary in applications.items() %}
        <a class="nav-item" href="{{ name }}/index.html" data-name="{{ name }}">{{ name }}</a>
      {% endfor %}
    </div>

    <div class="nav-footer">
      <div class="theme-switcher">
        <label><input type="radio" name="theme" value="light"><span>Light</span></label>
        <label><input type="radio" name="theme" value="auto"><span>Auto</span></label>
        <label><input type="radio" name="theme" value="dark"><span>Dark</span></label>
      </div>
    </div>
  </nav>

  <main>
    <div class="header-area">
      <h1>Gizmos :D</h1>
      <p style="color: var(--text-muted); font-family: var(--font-mono); font-size: 0.8rem; margin-top: 1rem;">STATUS: connected</p>
    </div>

    <div id="appContainer">
      {% for name, summary in applications.items() %}
        <section class="hud-card" id="card-{{ loop.index }}" data-name="{{ name }}">
          <div class="hud-texture"></div>
          <div class="card-header">
            <span class="unit-tag">REF_NO // {{ 1000 + loop.index }}</span>
            <a class="launch-btn" href="{{ name }}/index.html">Initialize</a>
          </div>
          <h2 class="app-title">{{ name }}</h2>
          <div class="summary-content">
            {{ summary | safe }}
          </div>
        </section>
      {% endfor %}
    </div>
  </main>

  <script src="https://40476.github.io/header/injector.js"></script>

  <script>
    /**
     * THEME LOGIC
     */
    function initTheme() {
      const savedTheme = localStorage.getItem('theme') || 'auto';
      const radio = document.querySelector(`input[name="theme"][value="${savedTheme}"]`);
      if (radio) radio.checked = true;

      applyTheme(savedTheme);

      document.querySelectorAll('input[name="theme"]').forEach(input => {
        input.addEventListener('change', (e) => {
          applyTheme(e.target.value);
        });
      });

      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', e => {
        if (localStorage.getItem('theme') === 'auto') applyTheme('auto');
      });
    }

    function applyTheme(theme) {
      const root = document.documentElement;
      let effectiveTheme = theme;
      if (theme === 'auto') {
        effectiveTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      root.setAttribute('data-theme', effectiveTheme);
      localStorage.setItem('theme', theme);
    }

    /**
     * HUD GENERATOR ENGINE
     */
    function mulberry32(seed) {
      let t = seed >>> 0;
      return function() {
        t += 0x6D2B79F5;
        let t2 = Math.imul(t ^ t >>> 15, t | 1);
        t2 ^= t2 + Math.imul(t2 ^ t2 >>> 7, t2 | 61);
        return ((t2 ^ t2 >>> 14) >>> 0) / 4294967296;
      };
    }

    function generateHudStylesForElement(el, seedValue) {
      const rng = mulberry32(seedValue);
      const w = el.offsetWidth;
      const h = el.offsetHeight;
      const chamferSize = () => (rng() > 0.3 ? Math.floor(rng() * 20 + 12) : 0);
      const corners = { tl: chamferSize(), tr: chamferSize(), br: chamferSize(), bl: chamferSize() };
      const toPct = (x, y) => `${(x / w * 100).toFixed(2)}% ${(y / h * 100).toFixed(2)}%`;

      let pts = [];
      pts.push(toPct(corners.tl, 0));
      pts.push(toPct(w - corners.tr, 0));
      if (corners.tr > 0) pts.push(toPct(w, corners.tr));
      pts.push(toPct(w, h - corners.br));
      if (corners.br > 0) pts.push(toPct(w - corners.br, h));
      pts.push(toPct(corners.bl, h));
      if (corners.bl > 0) pts.push(toPct(0, h - corners.bl));
      pts.push(toPct(0, corners.tl));

      el.style.setProperty('--outline', `polygon(${pts.join(', ')})`);

      const cornerKeys = ['tl', 'tr', 'br', 'bl'];
      cornerKeys.forEach(k => {
        if (rng() > 0.4) {
          const size = 15; const gap = 4;
          let triPts = [];
          if (k === 'tl') triPts = [toPct(gap, size+gap), toPct(gap, gap), toPct(size+gap, gap)];
          if (k === 'tr') triPts = [toPct(w-gap, size+gap), toPct(w-gap, gap), toPct(w-(size+gap), gap)];
          if (k === 'br') triPts = [toPct(w-gap, h-(size+gap)), toPct(w-gap, h-gap), toPct(w-(size+gap), h-gap)];
          if (k === 'bl') triPts = [toPct(gap, h-(size+gap)), toPct(gap, h-gap), toPct(size+gap, h-gap)];

          const tri = document.createElement('div');
          tri.className = 'hud-corner';
          tri.style.setProperty('--corner-path', `polygon(${triPts.join(', ')})`);
          el.appendChild(tri);
        }
      });
    }

    function initRegistry() {
      document.querySelectorAll('.hud-accent, .hud-corner').forEach(e => e.remove());
      const cards = document.querySelectorAll('.hud-card');
      cards.forEach((card, i) => {
        generateHudStylesForElement(card, 898766 + (i * 543));
      });
    }

    window.addEventListener('load', () => {
      initTheme();
      initRegistry();
      
      // REGISTER NAVIGATION API EXTENSIONS
      if(window.registerNavExtensions) {
        window.registerNavExtensions({
          search: {
            placeholder: "QUERY_MODULE...",
            onInput: (value) => {
              const term = value.toLowerCase();
              document.querySelectorAll(".hud-card").forEach(sec => {
                const name = sec.dataset.name.toLowerCase();
                sec.style.display = name.includes(term) ? "block" : "none";
              });
              document.querySelectorAll(".nav-item").forEach(item => {
                item.style.display = item.dataset.name.toLowerCase().includes(term) ? "block" : "none";
              });
            }
          },
          buttons: [
            {
              label: "SIDEBAR",
              onClick: () => {
                document.getElementById('sidebar').classList.toggle('open');
              }
            }
          ]
        });
      }
    });

    window.addEventListener('resize', initRegistry);
  </script> 
</body>
</html>

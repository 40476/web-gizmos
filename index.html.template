<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Applications Overview</title>

  <style>
    :root {
      --primary: #01ff70;
      --primary-hover: #2ecc40;
      --bg: #111;
      --card-bg: #222;
      --text: #fafafa;
      --text-muted: #bbb;
      --code-bg: #333;
      --sidebar-bg: #000;
      --border: #444;
    }

    /* Light Theme Overrides */
    body.light-theme {
      --bg: #f4f4f4;
      --card-bg: #ffffff;
      --sidebar-bg: #e0e0e0;
      --text: #111111;
      --text-muted: #444444;
      --border: #ccc;
      --code-bg: #eee;
    }


    body.light-theme #themeToggle {
      background: #111;
      color: var(--primary);
    }


    html { font-size: 16px; scroll-behavior: smooth; }
    
    body {
      margin: 0;
      font-family: "Courier New", Courier, monospace;
      background: var(--bg);
      color: var(--text);
      display: flex;
      min-height: 100vh;
      line-height: 1.45;
      overflow-x: hidden; /* Prevent global horizontal scroll */
    }

    /* Sidebar - Fixed and Stable */
    nav {
      width: 280px;
      background: var(--sidebar-bg);
      padding: 1.5rem;
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      box-sizing: border-box;
      z-index: 100;
    }

    nav h2 { 
      font-size: 1.5rem; 
      color: var(--primary); 
      margin-top: 0;
    }

    #search {
      width: 100%;
      padding: 10px;
      margin-bottom: 1rem;
      background: #111;
      border: 1px solid var(--border);
      color: var(--primary);
      border-radius: 4px;
      outline: none;
    }

    .nav-items-container {
      overflow-y: auto;
      flex-grow: 1;
    }

    .nav-item {
      display: block;
      color: var(--text-muted);
      text-decoration: none;
      padding: 5px 0;
      font-size: 0.9rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis; /* Truncate long names in sidebar */
    }

    .nav-item:hover { color: var(--primary); }

    /* Main Content Area */
    main {
      flex: 1;
      padding: 2rem 3rem;
      max-width: 50rem; /* Keeps lines readable */
      margin: 0 auto;
      box-sizing: border-box;
      width: 100%;
    }

    h1 { font-size: 2.5rem; color: var(--primary); margin-top: 0; }
    h2 { font-size: 1.8rem; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border); }

    /* Application Section Styling */
    .app-section {
      background: var(--card-bg);
      padding: 2rem;
      margin-bottom: 3rem;
      border-radius: 8px;
      border: 1px solid var(--border);
      /* Prevent injected content from breaking the card */
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    .app-link {
      color: var(--primary);
      text-decoration: none;
      font-weight: bold;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .app-link:hover { text-decoration: underline; }

    /* Injected Code Stability (The "Retro" Fix) */
    pre {
      background-color: var(--code-bg);
      padding: 1rem;
      overflow-x: auto; /* Forces scrollbar on long code lines */
      border-left: 3px solid var(--primary);
      margin: 1.5rem 0;
    }

    code {
      font-family: Menlo, Monaco, "Courier New", monospace;
      font-size: 0.9rem;
      color: #01ff70;
    }

    ul { padding-left: 1.2rem; }
    li { margin-bottom: 0.5rem; }

    /* Theme Toggle */
    #themeToggle {
      margin-top: 1rem;
      background: none;
      border: 1px solid var(--primary);
      color: var(--primary);
      padding: 5px 10px;
      cursor: pointer;
      font-family: inherit;
    }

    #themeToggle:hover { background: var(--primary); color: #000; }

    /* Mobile - Stack Layout */
    @media (max-width: 850px) {
      body { flex-direction: column; }
      nav { width: 100%; height: auto; position: relative; border-right: none; border-bottom: 1px solid var(--border); }
      main { padding: 1.5rem; width: 100%; }
    }
  </style>
</head>
<body>

  <nav>
    <h2>GIZMOS</h2>
    <input id="search" type="text" placeholder="Filter..." />
    <div class="nav-items-container">
      {% for name, summary in applications.items() %}
        <a class="nav-item" href="{{ name }}/index.html" data-name="{{ name }}">> {{ name }}</a>
      {% endfor %}
    </div>
    <button id="themeToggle">Toggle Theme</button>
  </nav>

  <main>
    <h1>web-gizmos (fun inside!)</h1>

    {% for name, summary in applications.items() %}
      <section class="app-section" id="section-{{ name }}" data-name="{{ name }}">
        <a class="app-link" href="{{ name }}/index.html">[ Run Application ]</a>
        <h2>{{ name }}</h2>
        <div class="summary-content">
          {{ summary | safe }}
        </div>
      </section>
    {% endfor %}
  </main>

  <script>
    const search = document.getElementById("search");
    const navItems = document.querySelectorAll(".nav-item");
    const sections = document.querySelectorAll(".app-section");

    search.addEventListener("input", () => {
      const q = search.value.toLowerCase();
      navItems.forEach(item => {
        item.style.display = item.dataset.name.toLowerCase().includes(q) ? "block" : "none";
      });
      sections.forEach(sec => {
        sec.style.display = sec.dataset.name.toLowerCase().includes(q) ? "block" : "none";
      });
    });

    const themeToggle = document.getElementById("themeToggle");

    themeToggle.addEventListener("click", () => {
      // This toggles the 'light-theme' class on the body
      document.body.classList.toggle("light-theme");

      // Optional: Change the button text based on the mode
      if (document.body.classList.contains("light-theme")) {
        themeToggle.textContent = "Dark Mode";
      } else {
        themeToggle.textContent = "Light Mode";
      }
    });
  </script>

</body>
</html>
